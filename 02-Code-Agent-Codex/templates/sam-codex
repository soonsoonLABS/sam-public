#!/usr/bin/env bash
set -euo pipefail

SAM_HOME="$HOME/.sam"
CODEX_SAM_HOME="$HOME/.codex-sam"
ENV_FILE="$SAM_HOME/env"

if [ ! -r "$ENV_FILE" ]; then
  echo "Missing $ENV_FILE. Run install-macos.sh first." >&2
  exit 1
fi

# shellcheck disable=SC1090
. "$ENV_FILE"

if [ -z "${SAM_CODEX_API:-}" ]; then
  echo "SAM_CODEX_API is not set in $ENV_FILE." >&2
  exit 1
fi

export CODEX_HOME="$CODEX_SAM_HOME"

# Codex treats ~/.codex/config.toml as a project layer when it is launched
# from $HOME or another non-repository directory below $HOME. That user-level
# OpenAI configuration could override SAM's isolated default model. Require a
# real repository for home-directory projects so discovery stops at its root.
if [[ "$PWD" == "$HOME" || "$PWD" == "$HOME/"* ]]; then
  if ! git -C "$PWD" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "Run sam-codex from a Git project directory, not $HOME." >&2
    echo "Example: cd ~/Developer/my-project && sam-codex" >&2
    exit 2
  fi
fi

refresh_model_catalog() {
  local catalog_tmp
  mkdir -p "$CODEX_HOME"
  umask 077
  catalog_tmp="$(mktemp "$CODEX_HOME/.models.XXXXXX")" || return 0
  if curl --fail --silent --show-error --max-time 10 \
    -H "Authorization: Bearer $SAM_CODEX_API" \
    'https://sam.soonsoon.ai/v2/openai/models' > "$catalog_tmp" \
    && grep -q '"models"' "$catalog_tmp"; then
    mv "$catalog_tmp" "$CODEX_HOME/models.json"
  else
    rm -f "$catalog_tmp"
  fi
}

refresh_model_catalog

if [[ ! -s "$CODEX_HOME/models.json" ]]; then
  echo "SAM model catalog could not be loaded; SAM Codex did not start." >&2
  echo "Check SAM API-key access and retry. Your normal OpenAI Codex was not changed." >&2
  exit 1
fi

catalog_config="model_catalog_json=\"$CODEX_HOME/models.json\""

models=(
  "azure.gpt-5.6-terra|Azure Foundry · everyday"
  "azure.gpt-5.6-sol|Azure Foundry · difficult work"
  "azure.gpt-5.6-luna|Azure Foundry · fast"
  "azure.gpt-5.4|Azure Foundry · GPT-5.4"
  "aws.gpt-5.6-terra|AWS Bedrock Mantle · everyday"
  "aws.gpt-5.6-sol|AWS Bedrock Mantle · difficult work"
  "aws.gpt-5.6-luna|AWS Bedrock Mantle · fast"
  "aws.gpt-5.5|AWS Bedrock Mantle · GPT-5.5"
  "aws.gpt-5.4|AWS Bedrock Mantle · GPT-5.4"
)

if [[ "${1:-}" == "model" ]]; then
  shift
  if [[ $# -gt 0 ]]; then
    selected_model="$1"
    shift
  else
    echo "Choose a SAM model"
    PS3="Enter a number: "
    select entry in "${models[@]}"; do
      if [[ -n "${entry:-}" ]]; then
        selected_model="${entry%%|*}"
        break
      fi
      echo "Enter a number from the list."
    done
  fi
  exec codex -c "$catalog_config" -m "$selected_model" "$@"
fi

exec codex -c "$catalog_config" "$@"
